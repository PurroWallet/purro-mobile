
# =========================================
# React Native Base .gitignore
# =========================================

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# Build directories
/android/app/build/
/android/.gradle/
/android/.idea/
/android/local.properties
/android/.cxx/
/android/app/.cxx/
/android/.project
/android/.settings
/android/build/
/ios/build/
/ios/DerivedData/
/ios/Pods/
/ios/*.xcworkspace

# Xcode user data
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log
log.txt

# Metro bundler
.bundle
.expo
.expo-shared
.expo-dev-client
dist/
web-build/

# Buck build system
buck-out/
.buckconfig.local

# Watchman
.watchmanconfig

# Android Studio
*.iml
.idea/
.gradle
/local.properties
captures/
output.json

# NDK / CMake
.cxx/
.externalNativeBuild/
*.so

# Misc build
tmp/
temp/
*.tmp
*.temp
*.bak

# VSCode
.vscode/
.history/
*.code-workspace

# Environment / config files
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
.env.test

# React Native specific
react-native.config.js
metro.config.js
babel.config.js

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# CocoaPods
Podfile.lock

# App Center / CodePush
appcenter-config.json
CodePush/
*.p8
*.mobileprovision
*.pem
*.key
*.keystore

# Expo EAS
eas.json
*.tar.gz

# Jest / testing
coverage/
jest-cache/
jest-html-reporters-*
*.test.js.snap

# Firebase / Google services
google-services.json
GoogleService-Info.plist

# Temporary files
*.swp
*.swo
*.orig

# Lint / TypeScript
.eslintcache
tsconfig.tsbuildinfo

# Project-specific cache
.cache/
.tmp/
coverage/
