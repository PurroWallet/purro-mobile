{
  "name": "capigrow",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "expo start --reset-cache",
    "web": "expo start --web",
    "build:android:prod": "bunx eas build --platform android --profile production",
    "build:ios:prod": "bunx eas build --platform ios --profile production",
    "lint:biome": "bunx @biomejs/biome lint ./src",
    "format": "bunx @biomejs/biome format --write ./src",
    "format:check": "bunx @biomejs/biome format ./src",
    "check": "bunx @biomejs/biome check --write ./src",
    "check:fix": "bunx @biomejs/biome check --write --unsafe ./src",
    "test:e2e": "playwright test",
    "open:xcode": "xed -b ios",
    "open:android": "open -a Android\\ Studio",
    "prepare": "husky",
    "reset:native": "rm -rf android && rm -rf ios && bunx expo prebuild",
    "reset": "rm -rf node_modules && rm -rf android && rm -rf ios && bun i && bunx expo install && bunx expo prebuild",
    "android": "bunx expo run:android",
    "ios": "bunx expo run:ios"
  },
  "dependencies": {
    "@ethereumjs/util": "^10.0.0",
