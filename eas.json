{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "channel": "preview",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_DISPLAY_NAME": "Purro Dev",
        "EXPO_PUBLIC_BUNDLE_ID": "com.purro.dev",
        "EXPO_PUBLIC_PACKAGE_NAME": "com.purro.dev",
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_URL": "https://api-dev.purro.com",
        "EXPO_PUBLIC_DEBUG_MODE": "true",
        "EXPO_PUBLIC_LOG_LEVEL": "debug",
        "EXPO_PUBLIC_ENABLE_MOCK_DATA": "true",
        "EXPO_PUBLIC_ENABLE_DEV_TOOLS": "true"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging"
      },
      "ios": {
        "enterpriseProvisioning": "universal"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_DISPLAY_NAME": "Capigrow",
        "EXPO_PUBLIC_BUNDLE_ID": "com.purro",
        "EXPO_PUBLIC_PACKAGE_NAME": "com.purro",
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_URL": "https://api.capigrow.com",
        "EXPO_PUBLIC_DEBUG_MODE": "false",
        "EXPO_PUBLIC_LOG_LEVEL": "error",
        "EXPO_PUBLIC_ENABLE_MOCK_DATA": "false",
        "EXPO_PUBLIC_ENABLE_DEV_TOOLS": "false"
      },
      "ios": {
        "autoIncrement": true,
        "image": "latest",
        "enterpriseProvisioning": "universal"
      },
      "android": {
        "autoIncrement": true,
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "phanhuypy.1999@gmail.com",
        "ascAppId": "6751463343",
        "appleTeamId": "4YYC9C23H7"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "phanhuypy.1999@gmail.com",
        "ascAppId": "6751463343",
        "appleTeamId": "4YYC9C23H7"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
