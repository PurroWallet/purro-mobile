{
  "$schema": "https://biomejs.dev/schemas/2.2.6/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "App.tsx",
      "src/**/*.{ts,tsx,js,jsx,json,css,md}",
      "__tests__/**/*.{ts,tsx,js,jsx,json,css,md}",
      "*.config.{js,ts}",
      "metro.config.js",
      "babel.config.js",
      "jest.config.js",
      "tailwind.config.js",
      "package.json",
      "tsconfig.json",
      "global.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "style": {
        "useImportType": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noTsIgnore": "off",
        "noUnknownAtRules": "off"
      },
      "correctness": {
        "noUnusedImports": "off",
        "noUnusedVariables": "off",
        "noUnusedFunctionParameters": "off",
        "useExhaustiveDependencies": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteStyle": "single"
    },
    "globals": ["__DEV__"]
  },
  "vcs": {
    "useIgnoreFile": true
  }
}
